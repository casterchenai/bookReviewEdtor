{
  "name": "book-review-editor",
  "version": "0.1.0",
  "private": true,
  "description": "BookReviewEditor — 图书出版前协同审校与修订管理平台",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:db": "npm run dev:db -w apps/api",
    "db:push": "npm run db:push -w apps/api",
    "db:seed": "npm run db:seed -w apps/api",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm run build -w apps/api && npm run build -w apps/web"
  },
  "engines": {
    "node": ">=20"
  }
}
