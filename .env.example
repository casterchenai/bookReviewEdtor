# ===== 数据库 =====
# 本地开发：`npm run dev:db` 会启动内嵌 Postgres（端口 5502，数据存于 apps/api/data/pg）
# 生产环境：改为你的 Postgres 连接串（或使用 docker-compose.yml）
DATABASE_URL="postgresql://postgres:postgres@localhost:5502/bookreview"

# ===== API 服务 =====
PORT=4000
JWT_SECRET="change-me-to-a-long-random-string"

# ===== 超级管理员（凭据存于环境变量）=====
# 系统启动时按此同步超管账户；用于管理系统用户、建书权限与全局 AI 配置
SUPER_ADMIN_EMAIL="admin@bookreview.local"
SUPER_ADMIN_PASSWORD="change-me-strong-password"
SUPER_ADMIN_NAME="超级管理员"

# ===== AI 智能审校（可选）=====
# 支持 OpenAI / 智谱 GLM / DeepSeek / Anthropic / Auto。
# 优先级：书稿专属配置 → 全局默认配置（后台设置）→ 下列环境变量。
# 全部留空时，AI 审校接口返回演示建议（stub）。
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GLM_API_KEY=""
DEEPSEEK_API_KEY=""
AI_MODEL="claude-sonnet-5"

# ===== 前端 =====
NEXT_PUBLIC_API_URL="http://localhost:4000"
