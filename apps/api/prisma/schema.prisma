generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== 用户与角色 =====

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String
  isAI          Boolean  @default(false) // AI 智能助手（系统内置账户）
  isSuperAdmin  Boolean  @default(false) // 超级管理员（凭据存于环境变量）
  canCreateBooks Boolean @default(true)  // 是否有创建书稿项目的权限
  createdAt     DateTime @default(now())

  memberships ProjectMember[]
  revisions   Revision[]
  comments    Comment[]
  ownedProjects Project[] @relation("ProjectOwner")
}

// 角色能力原型：动态角色（BookRole）在此四种能力之上叠加可编辑的显示名
enum ProjectRole {
  CHIEF_EDITOR // 主编/书管理员：把控整体质量、制定修订标准、定稿、管理成员与角色、配置本书 AI
  AGENT        // 内容顾问：评估内容导向、提出建议（可编辑内容、提交意见）
  REVIEWER     // 审校员：深度润色内容逻辑、表达风格、专业术语
  AI_ASSISTANT // AI 智能助手：智能校对、语法纠错、用词优化
}

// AI 供应商
enum AiProvider {
  AUTO      // 自动：按可用配置选择
  OPENAI
  GLM       // 智谱 GLM
  DEEPSEEK
  ANTHROPIC // Claude
}

// 每本书可自定义的角色（显示名可编辑，能力基于 ProjectRole 原型）
model BookRole {
  id        String      @id @default(cuid())
  projectId String
  name      String      // 可编辑的显示名，如「主编」「特邀审校」「市场顾问」
  base      ProjectRole // 能力原型，决定权限
  order     Int         @default(0)
  isDefault Boolean     @default(false) // 建书时自动创建的默认角色
  createdAt DateTime    @default(now())

  project Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members ProjectMember[]

  @@unique([projectId, name])
}

// 每本书的参考文献 / 资料（供 AI 设计智能体、及审校时据以核对）
model Reference {
  id          String   @id @default(cuid())
  projectId   String
  name        String   // 原始文件名
  mime        String   @default("")
  kind        String   @default("other") // pdf | word | sheet | slide | image | other
  size        Int      @default(0)
  textContent String   @default("") // 提取的文本（供 AI 阅读）
  dataBase64  String   @default("") // 原始文件 base64（供下载/预览；过大则为空）
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// 每本书的 AI 审校智能体（不同书可有不同智能体：名称 + 角色 + 技能提示词）
model AiAgent {
  id           String          @id @default(cuid())
  projectId    String
  name         String          // 智能体名称，如「会计准则合规审查」
  role         String          @default("") // 一句话角色定位
  systemPrompt String          // 该智能体的审校指令（“技能”）
  category     CommentCategory @default(GENERAL) // 意见默认归类
  enabled      Boolean         @default(true)
  order        Int             @default(0)
  createdAt    DateTime        @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// AI 配置：全局单例（projectId 为 null）或每本书覆盖（projectId 指向 Project）
model AiConfig {
  id        String     @id @default(cuid())
  projectId String?    @unique // null = 全局默认配置；非 null = 该书的专属配置
  provider  AiProvider @default(AUTO)
  model     String     @default("") // 具体模型 ID，如 gpt-4o、glm-4.6、deepseek-chat、claude-sonnet-5
  apiKey    String     @default("") // 该供应商的 API Key（为空则回退到环境变量）
  baseUrl   String     @default("") // 自定义端点（OpenAI 兼容），为空用供应商默认
  updatedAt DateTime   @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ===== 项目（书稿项目）=====

model Project {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  standards   String   @default("") // 主编制定的修订标准
  ownerId     String
  owner       User     @relation("ProjectOwner", fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     ProjectMember[]
  manuscripts Manuscript[]
  activities  Activity[]
  bookRoles   BookRole[]
  aiConfig    AiConfig?
  aiAgents    AiAgent[]
  references  Reference[]
}

model ProjectMember {
  id         String      @id @default(cuid())
  projectId  String
  userId     String
  role       ProjectRole // 能力原型（鉴权依据，向后兼容）
  bookRoleId String?     // 关联的可编辑角色（展示名）
  createdAt  DateTime    @default(now())

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookRole BookRole? @relation(fields: [bookRoleId], references: [id], onDelete: SetNull)

  @@unique([projectId, userId])
}

// ===== 书稿（章节）=====

enum ManuscriptStatus {
  DRAFT     // 草稿
  IN_REVIEW // 审校中
  FINALIZED // 已定稿（锁定，仅主编可解锁）
}

model Manuscript {
  id        String           @id @default(cuid())
  projectId String
  title     String
  order     Int              @default(0)
  status    ManuscriptStatus @default(DRAFT)
  content   String           @default("") // 纯文本投影（供 AI 审校/对比/搜索）
  docJson   String           @default("") // 结构化块内容（HTML/MD/PDF 解析结果）；为空表示纯文本
  section   String           @default("") // 所属部分（如「第一部分」「附录」），用于分组
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisions Revision[]
  comments  Comment[]

  @@index([projectId])
}

// ===== 修订记录（全流程可追溯）=====

model Revision {
  id           String   @id @default(cuid())
  manuscriptId String
  number       Int      // 版本号，从 1 递增
  authorId     String
  authorRole   ProjectRole
  content      String   // 该版本的纯文本快照
  docJson      String   @default("") // 该版本的结构化块快照
  summary      String   @default("") // 修订说明/原因
  createdAt    DateTime @default(now())

  manuscript Manuscript @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  author     User       @relation(fields: [authorId], references: [id])

  @@unique([manuscriptId, number])
  @@index([authorId])
}

// ===== 审阅意见与修改建议 =====

enum CommentStatus {
  OPEN     // 待处理
  RESOLVED // 已解决
  ACCEPTED // 建议已采纳
  REJECTED // 建议已驳回
}

enum CommentCategory {
  GENERAL   // 一般意见
  GRAMMAR   // 语法纠错
  WORDING   // 用词优化
  LOGIC     // 逻辑问题
  STYLE     // 表达风格
  MARKET    // 市场适配
  STANDARD  // 内容规范
}

model Comment {
  id             String          @id @default(cuid())
  manuscriptId   String
  authorId       String
  authorRole     ProjectRole
  paragraphIndex Int             // 锚定的段落序号
  quote          String          @default("") // 引用的原文片段
  body           String          // 意见内容
  category       CommentCategory @default(GENERAL)
  suggestedText  String?         // 修改建议文本（可被主编一键采纳）
  aiAgentName    String?         // 由某 AI 智能体产出时，记录其名称用于展示
  status         CommentStatus   @default(OPEN)
  createdAt      DateTime        @default(now())

  manuscript Manuscript @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  author     User       @relation(fields: [authorId], references: [id])

  @@index([manuscriptId])
  @@index([authorId])
}

// ===== 操作日志 =====

model Activity {
  id        String   @id @default(cuid())
  projectId String
  actorName String
  action    String
  detail    String   @default("")
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}
